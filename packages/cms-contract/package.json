{
  "name": "@cms-demo/cms-contract",
  "version": "0.2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./api-paths": {
      "types": "./dist/apiPaths.d.ts",
      "import": "./dist/apiPaths.js"
    },
    "./common": {
      "types": "./dist/common.d.ts",
      "import": "./dist/common.js"
    },
    "./news": {
      "types": "./dist/news.d.ts",
      "import": "./dist/news.js"
    },
    "./roadmap": {
      "types": "./dist/roadmap.d.ts",
      "import": "./dist/roadmap.js"
    },
    "./site": {
      "types": "./dist/site.d.ts",
      "import": "./dist/site.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsc -w",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
